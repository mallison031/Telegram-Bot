# Copy this file to .env and fill in your credentials

# Get from @BotFather on Telegram (/newbot)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Get from Google AI Studio (https://aistudio.google.com/apikey) - free tier
GEMINI_API_KEY=your-gemini-api-key-here

# Live prices come from Bybit's public API — no key or account needed.

# --- Optional settings (defaults shown) ---

# IANA timezone for the scheduled motivation messages. Set this — the default
# is UTC, which is why a message can arrive at the "wrong" hour.
#TIMEZONE=Africa/Lagos

# Hour of the day (0-23, in TIMEZONE) for each scheduled message
#MORNING_HOUR=8
#NIGHT_HOUR=22

# Stop monitoring a trade after this many hours with no TP/SL (0 = never)
#TRADE_TTL_HOURS=72

# Where to persist chat IDs and monitored trades. Point this at a mounted
# persistent disk if you want state to survive redeploys.
#STATE_FILE=state.json


