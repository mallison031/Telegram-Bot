# Copy this file to .env and fill in your credentials

# Get from @BotFather on Telegram (/newbot)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Get from Google AI Studio (https://aistudio.google.com/apikey) - free tier
GEMINI_API_KEY=your-gemini-api-key-here

# --- Optional settings (defaults shown) ---

# IANA timezone for the daily morning motivation message
#TIMEZONE=Africa/Lagos

# Hour of the day (0-23, in TIMEZONE) to send the morning message
#MORNING_HOUR=8


