# Copy this file to .env and fill in your credentials

# Get from @BotFather on Telegram (/newbot)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Get from Google AI Studio (https://aistudio.google.com/apikey) - free tier
GEMINI_API_KEY=your-gemini-api-key-here

# --- Live prices (optional but recommended) ---

# OANDA API token: sign up at https://www.oanda.com/, then in the account
# portal go to Manage API Access and generate a personal access token.
# Needed for forex, metals and indices (EURUSD, XAUUSD, US30...). Without it
# only crypto is monitored, via Bybit.
#OANDA_ACCESS_TOKEN=your-oanda-token-here

# Which environment the token belongs to: practice or live. Both carry the
# same live prices — only order execution differs, and this bot never trades.
#OANDA_ENV=practice

# Optional: pin one account. Left unset, the token's first account is used.
#OANDA_ACCOUNT_ID=101-004-12345678-001

# --- Optional settings (defaults shown) ---

# IANA timezone for the scheduled motivation messages. Set this — the default
# is UTC, which is why a message can arrive at the "wrong" hour.
#TIMEZONE=Africa/Lagos

# Hour of the day (0-23, in TIMEZONE) for each scheduled message
#MORNING_HOUR=8
#NIGHT_HOUR=22

# Stop monitoring a trade after this many hours with no TP/SL (0 = never)
#TRADE_TTL_HOURS=72

# Where to persist chat IDs and monitored trades. Point this at a mounted
# persistent disk if you want state to survive redeploys.
#STATE_FILE=state.json


